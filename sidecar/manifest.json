{
  "manifest_version": 3,
  "name": "Xenon Intelligence Sidecar",
  "version": "1.0",
  "description": "Seamlessly ingest Amazon and Flipkart reviews into Xenon Intelligence.",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "storage"
  ],
  "host_permissions": [
    "https://www.amazon.in/*",
    "https://www.flipkart.com/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.in/*",
        "https://www.flipkart.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
